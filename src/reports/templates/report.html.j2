<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Image Insight Report</title>
  <style>
    :root { color-scheme: light; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 32px; color: #111827; font-size: 11pt; line-height: 1.45; }
    h1 { font-size: 20pt; margin-bottom: 4px; }
    h2 { font-size: 13pt; margin-top: 24px; margin-bottom: 8px; }
    .meta { font-size: 9pt; color: #374151; }
    .meta-row { margin-bottom: 4px; }
    .card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 14px; background: #fafafa; }
    ul { padding-left: 20px; }

    @page {
      size: A4;
      margin: 16mm;
      @bottom-right { content: "Page " counter(page); font-size: 9pt; color: #6b7280; }
    }
  </style>
</head>
<body>
  <h1>Image Insight Report</h1>
  <p class="meta">Generated: {{ generated_at }}</p>

  <div class="card meta">
    <div class="meta-row"><strong>Report ID:</strong> {{ report_id }}</div>
    <div class="meta-row"><strong>Job ID:</strong> {{ job_id }}</div>
    <div class="meta-row"><strong>Image SHA-256:</strong> {{ image_sha256 }}</div>
    <div class="meta-row"><strong>Analyzer Version:</strong> {{ analyzer_version }}</div>
  </div>

  <h2>Summary</h2>
  <p>{{ summary }}</p>

  <h2>Tags</h2>
  <ul>
    {% for tag in tags %}
    <li>{{ tag }}</li>
    {% endfor %}
  </ul>

  <h2>Confidence</h2>
  <p>{{ confidence }}</p>
</body>
</html>
